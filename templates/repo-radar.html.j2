<!doctype html>
<html lang="ja">
<head>
  {% include "_head.html.j2" %}
  <title>Repo Radar — AI-Pulse</title>
  <style>
    .rr-head { padding: var(--s-32) 0 var(--s-24); border-bottom: 1px solid var(--border); }
    .rr-head .kicker, .rr-meta, .rr-list-head { display: flex; align-items: center; gap: var(--s-16); flex-wrap: wrap; }
    .rr-head h1 {
      margin: var(--s-16) 0 var(--s-8);
      font-size: clamp(28px, 4.2vw, 44px);
      line-height: 1.18;
      letter-spacing: 0;
      text-wrap: balance;
    }
    .rr-head .lead { margin: 0; max-width: 78ch; color: var(--fg-sub); font-size: var(--t-sm); line-height: 1.9; }
    .rr-meta { margin-top: var(--s-16); gap: var(--s-8); }
    .rr-meta span {
      border: 1px solid var(--border);
      background: var(--bg-elev);
      color: var(--fg-sub);
      border-radius: var(--r-sm);
      padding: 6px 9px;
      font-family: var(--font-mono);
      font-size: var(--t-label);
    }
    .rr-legend {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      margin: var(--s-24) 0;
      border: 1px solid var(--border);
      background: var(--border-soft);
      border-radius: var(--r-sm);
      overflow: hidden;
    }
    .rr-legend div { background: var(--bg-elev); padding: 12px 14px; min-width: 0; }
    .rr-legend b { display: block; color: var(--fg); font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; }
    .rr-legend span { display: block; margin-top: 4px; color: var(--fg-mute); font-size: 12px; line-height: 1.55; }
    .rr-toolbar {
      position: sticky;
      top: var(--header-h);
      z-index: 35;
      margin: 0 calc(var(--s-24) * -1);
      padding: 11px var(--s-24);
      background: color-mix(in oklab, var(--bg) 90%, transparent);
      border-bottom: 1px solid var(--border-soft);
      backdrop-filter: blur(14px);
      display: flex;
      gap: var(--s-8);
      overflow-x: auto;
    }
    .rr-search {
      min-width: 240px;
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
      background: var(--bg-elev);
      color: var(--fg);
      font-family: var(--font-mono);
      font-size: var(--t-label);
      padding: 8px 10px;
    }
    .rr-sort { display: inline-flex; border: 1px solid var(--border); border-radius: var(--r-sm); overflow: hidden; flex: 0 0 auto; }
    .rr-sort button {
      border: 0;
      border-right: 1px solid var(--border);
      background: var(--bg-elev);
      color: var(--fg-sub);
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 8px 10px;
      cursor: pointer;
    }
    .rr-sort button:last-child { border-right: 0; }
    .rr-sort button[aria-pressed="true"] { background: var(--accent); color: var(--accent-fg); }
    .rr-list-head { justify-content: space-between; margin-top: var(--s-24); }
    .rr-list-head h2 { margin: 0; font-size: var(--t-h2); letter-spacing: 0; }
    .repo-list { list-style: none; margin: 0; padding: var(--s-16) 0 var(--s-48); display: grid; gap: var(--s-24); }
    .repo-card {
      display: grid;
      grid-template-columns: 304px minmax(0, 1fr);
      gap: var(--s-24);
      padding: var(--s-24);
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-left: 3px solid var(--cat);
      border-radius: var(--r-sm);
      box-shadow: var(--shadow-1);
      transition: border-color .16s, box-shadow .16s;
    }
    .repo-card:hover { border-color: var(--border-strong); border-left-color: var(--cat); box-shadow: var(--shadow-2); }
    .repo-aside { display: flex; flex-direction: column; gap: var(--s-16); min-width: 0; }
    .badge-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: var(--s-8); }
    .lic-tag {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
      color: var(--fg-sub);
      background: var(--bg-elev-2);
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 8px;
    }
    .rail-id h2 {
      margin: 0;
      color: var(--fg);
      font-size: 34px;
      line-height: 1.14;
      letter-spacing: 0;
      word-break: break-word;
      text-wrap: balance;
    }
    .repo-card:hover .rail-id h2 { color: var(--accent); }
    .rail-id .url { display: inline-block; margin-top: 6px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 11.5px; word-break: break-all; }
    .utility { display: flex; align-items: end; justify-content: space-between; gap: var(--s-16); }
    .utility .score { color: var(--cat); font-family: var(--font-mono); font-size: 40px; font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }
    .u-meta { display: grid; justify-items: end; gap: 6px; }
    .u-lbl { color: var(--fg-mute); font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; }
    .prio { display: inline-flex; align-items: center; gap: 6px; border-radius: var(--r-sm); padding: 3px 8px; font-family: var(--font-mono); font-size: 11px; }
    .prio .pdot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
    .prio[data-prio="高"] { color: var(--imp-high); background: color-mix(in oklab, var(--imp-high) 14%, transparent); }
    .prio[data-prio="中"] { color: var(--imp-mid); background: color-mix(in oklab, var(--imp-mid) 14%, transparent); }
    .prio[data-prio="低"] { color: var(--fg-sub); background: var(--bg-elev-2); }
    .metrics { display: grid; gap: 1px; background: var(--border-soft); border: 1px solid var(--border); border-radius: var(--r-sm); overflow: hidden; }
    .metrics .m { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; background: var(--bg); padding: 9px 13px; }
    .metrics .mk { display: inline-flex; align-items: center; gap: 7px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .14em; }
    .metrics .mv { color: var(--fg); font-family: var(--font-mono); font-weight: 700; font-size: 21px; line-height: 1; font-variant-numeric: tabular-nums; }
    .metrics .mv .sub { margin-left: 5px; color: var(--fg-mute); font-size: 11px; font-weight: 400; }
    .metrics .mv.star { color: var(--imp-mid); }
    .fresh { width: 7px; height: 7px; border-radius: 50%; background: var(--border-strong); display: inline-block; }
    .fresh[data-f="hot"] { background: var(--c-agent); box-shadow: 0 0 7px var(--c-agent); }
    .fresh[data-f="warm"] { background: var(--imp-mid); }
    .fresh[data-f="cold"] { background: var(--fg-mute); }
    .og {
      display: block;
      text-decoration: none;
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
      background: var(--bg-elev-2);
      overflow: hidden;
      transition: border-color .14s;
    }
    .og:hover { border-color: var(--border-strong); }
    .og-img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border-bottom: 1px solid var(--border); background: var(--bg); }
    .og-body { padding: 12px 13px; }
    .og .gh { color: var(--fg-mute); font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; }
    .og .og-title { margin-top: 5px; color: var(--fg); font-family: var(--font-mono); font-size: 13px; line-height: 1.4; word-break: break-all; }
    .og .og-title b { color: var(--cat); }
    .og .og-desc { margin: 7px 0 0; color: var(--fg-sub); font-size: 12px; line-height: 1.6; }
    .og-stats { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 10.5px; }
    .lang-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: var(--lang); }
    .lang-bar { height: 3px; background: var(--lang); }
    .gh-link {
      display: flex;
      justify-content: space-between;
      align-items: center;
      min-height: 38px;
      padding: 0 12px;
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
      color: var(--fg);
      background: var(--bg);
      font-family: var(--font-mono);
      font-size: 12px;
    }
    .gh-link:hover { border-color: var(--cat); color: var(--cat); }
    .gh-link .arr { transition: transform .14s; }
    .gh-link:hover .arr { transform: translateX(3px); }
    .repo-body { display: flex; flex-direction: column; gap: var(--s-24); min-width: 0; }
    .block-label { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 10px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .11em; text-transform: uppercase; }
    .block-label::before { content: ""; width: 4px; height: 12px; background: var(--cat); border-radius: 1px; }
    .embed {
      display: block;
      border: 1px solid var(--border);
      border-left: 3px solid var(--src-c);
      border-radius: var(--r-sm);
      background: var(--bg);
      padding: 14px 16px;
      text-decoration: none;
    }
    .embed:hover { background: var(--bg-elev-2); border-color: var(--border-strong); border-left-color: var(--src-c); }
    .embed[data-src="reddit"] { --src-c: oklch(0.70 0.18 32); }
    .embed[data-src="x"] { --src-c: oklch(0.86 0.004 265); }
    .embed[data-src="hn"] { --src-c: oklch(0.70 0.17 48); }
    .embed[data-src="github"] { --src-c: var(--tier-1); }
    .em-url { display: block; margin-bottom: 11px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 10.5px; word-break: break-all; }
    .em-head { display: flex; align-items: center; gap: 11px; margin-bottom: 9px; }
    .em-avatar { display: grid; place-items: center; width: 30px; height: 30px; border-radius: 50%; background: var(--src-c); color: var(--bg); font-family: var(--font-mono); font-weight: 700; font-size: 12px; flex: 0 0 auto; }
    .em-name { color: var(--fg); font-weight: 700; line-height: 1.35; }
    .em-name em { display: block; color: var(--fg-mute); font-style: normal; font-family: var(--font-mono); font-size: 10.5px; font-weight: 400; }
    .src-pill { margin-left: auto; color: var(--src-c); border: 1px solid color-mix(in oklab, var(--src-c) 45%, var(--border)); border-radius: 99px; padding: 2px 8px; font-family: var(--font-mono); font-size: 10px; }
    .body-list { margin: 8px 0 0; padding: 0; list-style: none; display: grid; gap: 8px; }
    .body-list li { position: relative; padding-left: 16px; color: var(--fg-sub); line-height: 1.75; }
    .body-list li::before { content: ""; position: absolute; left: 0; top: .82em; width: 5px; height: 5px; background: var(--cat); border-radius: 50%; }
    .body-list b { color: var(--fg); font-weight: 700; }
    .body-list u { text-decoration-color: var(--cat); text-decoration-thickness: 2px; text-underline-offset: 3px; }
    .body-list mark { background: color-mix(in oklab, var(--cat) 26%, transparent); color: var(--fg); }
    .em-body { color: var(--fg-sub); font-size: 13px; }
    .em-foot { display: flex; justify-content: space-between; gap: 12px; margin-top: 12px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 10.5px; }
    .lens { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px; background: var(--border-soft); border: 1px solid var(--border); border-radius: var(--r-sm); overflow: hidden; }
    .axis { background: var(--bg); padding: 13px 14px; min-width: 0; }
    .axis.watch { background: color-mix(in oklab, var(--imp-mid) 9%, var(--bg)); }
    .ax-k { display: block; color: var(--cat); font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; line-height: 1.35; }
    .ax-k em { display: block; color: var(--fg-mute); font-style: normal; letter-spacing: 0; }
    .axis-list { font-size: 13px; }
    .opsfit { background: var(--bg); border: 1px solid var(--border); border-left: 2px solid var(--cat); border-radius: var(--r-sm); padding: 14px 16px; }
    .opsfit .reason { color: var(--fg); font-size: 14px; }
    .opsfit .reason b { color: var(--cat); }
    .opsfit .facts { display: flex; flex-wrap: wrap; align-items: center; gap: var(--s-24); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border-soft); }
    .fact { display: inline-flex; align-items: center; gap: 9px; }
    .fact .fk { color: var(--fg-mute); font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .12em; }
    .fact .fv { color: var(--fg-sub); font-family: var(--font-mono); font-size: 12.5px; }
    .fact .bars { display: inline-flex; gap: 2px; }
    .fact .bars i { width: 4px; height: 12px; background: var(--border-strong); display: block; }
    .fact[data-level="高"] .bars i { background: var(--imp-high); }
    .fact[data-level="中"] .bars i:nth-child(-n+2) { background: var(--imp-mid); }
    .fact[data-level="低"] .bars i:nth-child(1) { background: var(--c-agent); }
    .fact[data-level="高"] .fv { color: var(--imp-high); }
    .fact[data-level="中"] .fv { color: var(--imp-mid); }
    .fact[data-level="低"] .fv { color: var(--c-agent); }
    .rr-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: var(--s-16); }
    .rr-tags span {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 3px 8px;
      border: 1px solid color-mix(in oklab, var(--cat) 32%, var(--border));
      color: var(--fg);
      background: color-mix(in oklab, var(--cat) 9%, transparent);
      border-radius: var(--r-sm);
      font-size: 12.5px;
      line-height: 1.3;
    }
    .empty { display: none; padding: var(--s-48) 0; text-align: center; color: var(--fg-mute); font-family: var(--font-mono); font-size: var(--t-sm); }
    .rr-empty { margin: var(--s-32) 0; padding: var(--s-24); background: var(--bg-elev); border: 1px solid var(--border); border-radius: var(--r-md); color: var(--fg-sub); }
    @media (max-width: 900px) {
      .repo-card { grid-template-columns: 1fr; }
      .repo-aside { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-16) var(--s-24); }
      .rail-id, .og, .gh-link { grid-column: 1 / -1; }
    }
    @media (max-width: 720px) {
      .rr-legend { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .rr-toolbar { top: var(--header-h); }
      .rr-search { min-width: 190px; }
    }
    @media (max-width: 620px) {
      .repo-aside, .lens { grid-template-columns: 1fr; }
      .rail-id h2 { font-size: 28px; }
      .utility .score { font-size: 34px; }
      .em-body, .axis-list { font-size: 12.5px; }
    }
  </style>
</head>
<body data-page="repo_radar">
  {% include "_header.html.j2" %}
  <main class="wrap">
    <section class="rr-head">
      <div class="kicker">
        <span class="dateline"><span class="live-dot"></span> {{ ref_date_label }}</span>
        <span class="label">リポジトリ一覧 / REPOSITORY LIST</span>
        <span class="count-pill"><b data-count>{{ "%02d"|format(repo_radar_count) }}</b> repos</span>
      </div>
      <h1>AI駆動開発に資するGithub Repository</h1>
      <p class="lead">Reddit / Hacker News / GitHub で話題になった GitHub リポジトリを収集し、AI-Pulse の開発・運用に取り込む価値を「発見のきっかけ → 機能 → 採用判断」の順で読むための採用候補ダッシュボードです。</p>
      <div class="rr-meta">
        <span>最新評価 {{ repo_radar_latest or "未実行" }}</span>
        <span>公開面は IdeaStash の具体タスク名を匿名化</span>
        <span>source: {{ repo_radar_sources | join(" / ") or "Reddit / HN / GitHub" }}</span>
      </div>
    </section>

    <section class="rr-legend" aria-label="Adoption Lens">
      <div><b>WHAT IT DOES</b><span>できること。repo の中核機能を一行で把握する。</span></div>
      <div><b>WHERE IT FITS</b><span>組み込み先。AI-Pulse のどこに効くかを見る。</span></div>
      <div><b>WHAT TO WATCH</b><span>注意点。ライセンス、依存、成熟度を先に見る。</span></div>
      <div><b>WHY FOR US</b><span>効用。自分たちが採用候補にする理由を固定する。</span></div>
    </section>

    <section class="rr-toolbar" aria-label="Repo Radar controls">
      <input class="rr-search" type="search" data-search placeholder="repo / trigger / lens を検索" aria-label="リポジトリ検索" />
      <div class="rr-sort" data-sort-bar aria-label="並び替え">
        <button type="button" data-sort="score" aria-pressed="true">SCORE</button>
        <button type="button" data-sort="stars" aria-pressed="false">Stars</button>
        <button type="button" data-sort="fresh" aria-pressed="false">更新</button>
      </div>
      <div class="chip-row" data-filter-bar aria-label="カテゴリフィルタ">
        <button class="chip all" type="button" aria-pressed="true">All</button>
        {% for c in repo_radar_categories %}
        <button class="chip" type="button" data-cat="{{ c.cat }}" aria-pressed="true">
          <span class="gly">{{ c.glyph }}</span>{{ c.cat_label }}
        </button>
        {% endfor %}
      </div>
    </section>

    {% if not repo_radar %}
    <section class="rr-empty">
      Repo Radar はまだ評価結果を持っていません。日次バッチが Reddit / HN / GitHub API から候補を収集すると、このページにリポジトリ評価が表示されます。
    </section>
    {% else %}
    <div class="rr-list-head">
      <h2>採用候補</h2>
      <span class="count-pill"><b data-count>{{ "%02d"|format(repo_radar_count) }}</b> / {{ "%02d"|format(repo_radar_count) }} 件を表示</span>
    </div>
    <ol class="repo-list" data-repo-list>
      {% for r in repo_radar %}
      <li class="repo-card" data-filter-item data-cat="{{ r.cat }}" data-score="{{ r.score }}" data-stars="{{ r.stars_num }}" data-fresh="{{ r.fresh_days }}">
        <div class="repo-aside">
          <div class="rail-id">
            <div class="badge-row">
              <span class="cat-badge"><span class="gly">{{ r.glyph }}</span>{{ r.cat_label }}</span>
              <span class="lic-tag">{{ r.license or r.pricing_or_license or "license n/a" }}</span>
            </div>
            <h2><a href="{{ r.repo_url }}" target="_blank" rel="noopener noreferrer">{{ r.name }}</a></h2>
            <a class="url" href="{{ r.repo_url }}" target="_blank" rel="noopener noreferrer">{{ r.repo_url | replace("https://", "") }}</a>
          </div>

          <div class="utility">
            <span class="score">{{ r.score }}</span>
            <div class="u-meta">
              <span class="u-lbl">UTILITY SCORE</span>
              <span class="prio" data-prio="{{ r.priority }}"><span class="pdot"></span>優先度 {{ r.priority }}</span>
            </div>
          </div>

          <div class="metrics" aria-label="Repository metrics">
            <div class="m"><span class="mk">STARS</span><span class="mv star">★ {{ r.stars_label }}</span></div>
            <div class="m"><span class="mk">CREATED</span><span class="mv">{{ r.created_label }}{% if r.age_label %}<span class="sub">{{ r.age_label }}</span>{% endif %}</span></div>
            <div class="m"><span class="mk"><span class="fresh" data-f="{{ r.fresh_kind }}"></span>UPDATED</span><span class="mv">{{ r.fresh_label }}</span></div>
          </div>

          <a class="og" href="{{ r.repo_url }}" target="_blank" rel="noopener noreferrer" style="--lang: {{ r.lang_color }}">
            <img class="og-img" src="{{ r.thumbnail_url or ('https://opengraph.githubassets.com/ai-pulse/' ~ r.repo) }}" alt="{{ r.repo }} repository preview" loading="lazy" />
            <div class="og-body">
              <span class="gh">GitHub</span>
              <div class="og-title">{{ r.repo.split("/")[0] }}/<b>{{ r.repo.split("/")[-1] }}</b></div>
              <p class="og-desc">{{ r.description or r.summary }}</p>
              <div class="og-stats">
                <span>★ {{ r.stars_label }}</span>
                <span>⑂ {{ r.forks }}</span>
                <span>⊙ {{ r.open_issues }}</span>
                <span><span class="lang-dot"></span> {{ r.language or "n/a" }}</span>
              </div>
            </div>
            <div class="lang-bar"></div>
          </a>

          <a class="gh-link" href="{{ r.repo_url }}" target="_blank" rel="noopener noreferrer">リポジトリを開く <span class="arr">→</span></a>
        </div>

        <article class="repo-body">
          <section class="trigger">
            <span class="block-label">採用のきっかけ · TRIGGER</span>
            <a class="embed" data-src="{{ r.trigger.src }}" href="{{ r.trigger.url }}" target="_blank" rel="noopener noreferrer" title="元の投稿を開く">
              <span class="em-url">{{ r.trigger.url_text }}</span>
              <div class="em-head">
                <span class="em-avatar">{{ r.trigger.avatar }}</span>
                <span class="em-name">{{ r.trigger.title }}<em>{{ r.trigger.sub }}</em></span>
                <span class="src-pill">{{ r.trigger.label }}</span>
              </div>
              <ul class="body-list em-body">
                {% for item in r.summary_items or [r.summary] %}<li>{{ item|emph }}</li>{% endfor %}
              </ul>
              <div class="em-foot">
                <span>{{ r.trigger.label }} · {{ r.date }}</span>
                <span>{{ r.trigger.stat }}</span>
              </div>
            </a>
          </section>

          <section>
            <span class="block-label">機能概要 · Adoption Lens</span>
            <div class="lens">
              <div class="axis"><span class="ax-k">WHAT IT DOES <em>できること</em></span><ul class="body-list axis-list">{% for item in r.outline.what_items or [r.outline.what] %}<li>{{ item|emph }}</li>{% endfor %}</ul></div>
              <div class="axis"><span class="ax-k">WHERE IT FITS <em>組み込み先</em></span><ul class="body-list axis-list">{% for item in r.outline.where_items or [r.outline.where] %}<li>{{ item|emph }}</li>{% endfor %}</ul></div>
              <div class="axis watch"><span class="ax-k">WHAT TO WATCH <em>注意点</em></span><ul class="body-list axis-list">{% for item in r.outline.watch_items or [r.outline.watch] %}<li>{{ item|emph }}</li>{% endfor %}</ul></div>
              <div class="axis"><span class="ax-k">WHY FOR US <em>効用</em></span><ul class="body-list axis-list">{% for item in r.outline.why_items or [r.outline.why] %}<li>{{ item|emph }}</li>{% endfor %}</ul></div>
            </div>
          </section>

          <section class="opsfit">
            <span class="block-label">採用理由 · OPS FIT</span>
            <ul class="body-list reason">
              {% for item in r.adoption_items or [r.adoption_reason or r.developer_use_case] %}<li>{{ item|emph }}</li>{% endfor %}
            </ul>
            <div class="facts">
              <span class="fact" data-level="{{ r.effort }}"><span class="fk">導入負荷</span><span class="bars"><i></i><i></i><i></i></span><span class="fv">{{ r.effort }}</span></span>
              <span class="fact"><span class="fk">ライセンス</span><span class="fv">{{ r.pricing_or_license or r.license or "n/a" }}</span></span>
              <span class="fact"><span class="fk">依存</span><span class="fv">{{ r.language or "n/a" }}{% if r.release_label %} · {{ r.release_label }}{% endif %}</span></span>
            </div>
            <div class="rr-tags" aria-label="AI-Pulse 適用候補">
              {% for fit in r.ai_pulse_fit or [] %}<span>{{ fit }}</span>{% endfor %}
              {% for fit in r.ideastash_fit_public or [] %}<span>{{ fit }}</span>{% endfor %}
            </div>
          </section>
        </article>
      </li>
      {% endfor %}
    </ol>
    <p class="empty">該当するリポジトリはありません。</p>
    {% endif %}
  </main>
  {% include "_footer.html.j2" %}
  <script src="app.js"></script>
  <script>
  (function () {
    var list = document.querySelector("[data-repo-list]");
    var bar = document.querySelector("[data-sort-bar]");
    if (!list || !bar) return;
    function sortBy(key) {
      var cards = Array.prototype.slice.call(list.querySelectorAll(".repo-card"));
      cards.sort(function (a, b) {
        if (key === "fresh") return (+a.dataset.fresh || 9999) - (+b.dataset.fresh || 9999);
        if (key === "stars") return (+b.dataset.stars || 0) - (+a.dataset.stars || 0);
        return (+b.dataset.score || 0) - (+a.dataset.score || 0);
      });
      cards.forEach(function (card) { list.appendChild(card); });
      bar.querySelectorAll("button").forEach(function (btn) {
        btn.setAttribute("aria-pressed", String(btn.dataset.sort === key));
      });
    }
    bar.addEventListener("click", function (ev) {
      var btn = ev.target.closest("button[data-sort]");
      if (btn) sortBy(btn.dataset.sort);
    });
    sortBy("score");
  })();
  </script>
</body>
</html>

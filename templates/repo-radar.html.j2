<!doctype html>
<html lang="ja">
<head>
  {% include "_head.html.j2" %}
  <title>Repo Radar — AI-Pulse</title>
  <style>
    .radar-head { padding: var(--s-32) 0 var(--s-24); border-bottom: 1px solid var(--border); }
    .radar-head .kicker { display: flex; align-items: center; gap: var(--s-16); flex-wrap: wrap; }
    .radar-head h1 {
      margin: var(--s-16) 0 var(--s-8);
      font-size: var(--t-display);
      letter-spacing: 0;
      line-height: 1.16;
      max-width: 14ch;
    }
    .radar-head h1 mark {
      background: var(--accent);
      color: var(--accent-fg);
      padding: 0 0.08em;
      border-radius: var(--r-sm);
    }
    .radar-head .lead { margin: 0; max-width: 72ch; color: var(--fg-sub); font-size: var(--t-sm); }
    .radar-meta {
      display: flex; flex-wrap: wrap; gap: var(--s-8);
      margin-top: var(--s-16);
    }
    .radar-meta span {
      border: 1px solid var(--border);
      background: var(--bg-elev);
      color: var(--fg-sub);
      border-radius: var(--r-sm);
      padding: 6px 9px;
      font-family: var(--font-mono);
      font-size: var(--t-label);
    }
    .radar-list { list-style: none; margin: 0; padding: var(--s-24) 0 var(--s-48); display: grid; gap: var(--s-16); }
    .radar-card {
      display: grid;
      grid-template-columns: 148px minmax(0, 1fr);
      gap: var(--s-24);
      padding: var(--s-24);
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-left: 4px solid var(--accent);
      border-radius: var(--r-md);
      box-shadow: var(--shadow-1);
    }
    .radar-card:hover { border-left-color: var(--c-agent); background: color-mix(in oklab, var(--bg-elev) 90%, var(--accent)); }
    .radar-side { min-width: 0; }
    .radar-thumb {
      display: block;
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      background: var(--bg-elev-2);
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
    }
    .radar-score .num {
      display: block;
      margin-top: var(--s-12, 12px);
      font-family: var(--font-mono);
      font-size: 30px;
      line-height: 1;
      color: var(--accent);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .radar-score .lbl {
      display: block;
      margin-top: 5px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      color: var(--fg-mute);
    }
    .radar-body { min-width: 0; }
    .radar-topline { display: flex; flex-wrap: wrap; align-items: center; gap: var(--s-8); margin-bottom: var(--s-8); }
    .radar-repo {
      font-family: var(--font-mono);
      color: var(--c-editor);
      font-size: var(--t-sm);
      overflow-wrap: anywhere;
    }
    .radar-date { color: var(--fg-mute); font-family: var(--font-mono); font-size: var(--t-label); }
    .radar-card h2 {
      margin: 0 0 var(--s-8);
      font-size: var(--t-h2);
      line-height: 1.35;
      letter-spacing: 0;
      overflow-wrap: anywhere;
    }
    .radar-card h2 a:hover { color: var(--accent); }
    .radar-summary { margin: 0 0 var(--s-16); color: var(--fg-sub); font-size: var(--t-sm); line-height: 1.75; }
    .radar-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--s-8);
      margin: var(--s-12, 12px) 0 var(--s-16);
    }
    .radar-metric {
      border: 1px solid var(--border);
      background: var(--bg);
      border-radius: var(--r-sm);
      padding: var(--s-8);
      min-width: 0;
    }
    .metric-label {
      display: block;
      color: var(--fg-mute);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .metric-value {
      display: block;
      margin-top: 3px;
      color: var(--fg);
      font-family: var(--font-mono);
      font-size: 20px;
      font-weight: 700;
      line-height: 1.1;
      font-variant-numeric: tabular-nums;
      overflow-wrap: anywhere;
    }
    .radar-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--s-12, 12px);
    }
    .radar-box {
      border-top: 1px solid var(--border);
      padding-top: var(--s-8);
      min-width: 0;
    }
    .radar-box .label { display: block; margin-bottom: 3px; }
    .radar-box p { margin: 0; color: var(--fg-sub); font-size: 13.5px; line-height: 1.7; }
    .radar-box.wide { grid-column: 1 / -1; }
    .radar-outline,
    .radar-signals {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 7px;
    }
    .radar-outline li,
    .radar-signals li {
      color: var(--fg-sub);
      font-size: 13.5px;
      line-height: 1.65;
    }
    .radar-outline b,
    .radar-signals b {
      color: var(--fg);
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .radar-signals a { color: var(--c-editor); overflow-wrap: anywhere; }
    .radar-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: var(--s-8); }
    .radar-tags span {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 3px 8px;
      border: 1px solid color-mix(in oklab, var(--accent) 36%, var(--border));
      color: var(--fg);
      background: color-mix(in oklab, var(--accent) 10%, transparent);
      border-radius: var(--r-sm);
      font-size: 12.5px;
      line-height: 1.3;
    }
    .radar-stats { display: flex; flex-wrap: wrap; gap: 10px; margin-top: var(--s-12, 12px); }
    .radar-stats span { color: var(--fg-mute); font-family: var(--font-mono); font-size: 11.5px; }
    .radar-empty {
      margin: var(--s-32) 0;
      padding: var(--s-24);
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      color: var(--fg-sub);
    }
    @media (max-width: 760px) {
      .radar-card { grid-template-columns: 1fr; gap: var(--s-16); }
      .radar-thumb { max-width: 320px; }
      .radar-score { display: flex; align-items: baseline; gap: 8px; }
      .radar-score .num { margin-top: 0; }
      .radar-metrics { grid-template-columns: 1fr; }
      .radar-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body data-page="repo_radar">
  {% include "_header.html.j2" %}
  <main class="wrap">
    <section class="radar-head">
      <div class="kicker">
        <span class="label">Repo Radar</span>
        <span class="count-pill"><b data-count>{{ "%02d"|format(repo_radar_count) }}</b> repos</span>
      </div>
      <h1>AI開発に効く<mark>話題リポジトリ</mark></h1>
      <p class="lead">Reddit と Hacker News で見つかった GitHub リポジトリを GitHub API で確認し、ローカル Ollama が機能・導入難易度・課金/ライセンス・AI-Pulse への効用を一次評価します。</p>
      <div class="radar-meta">
        <span>最新評価 {{ repo_radar_latest or "未実行" }}</span>
        <span>公開面は IdeaStash の具体タスク名を匿名化</span>
        <span>source: Reddit / HN / GitHub</span>
      </div>
    </section>

    {% if not repo_radar %}
    <section class="radar-empty">
      Repo Radar はまだ評価結果を持っていません。日次バッチが Reddit / HN / GitHub API から候補を収集すると、このページにリポジトリ評価が表示されます。
    </section>
    {% else %}
    <ol class="radar-list">
      {% for r in repo_radar %}
      <li class="radar-card">
        <div class="radar-side">
          <img
            class="radar-thumb"
            src="{{ r.thumbnail_url or ('https://opengraph.githubassets.com/ai-pulse/' ~ r.repo) }}"
            alt="{{ r.repo }} repository preview"
            loading="lazy"
          />
          <div class="radar-score">
            <span class="num">{{ r.score }}</span>
            <span class="lbl">UTILITY</span>
          </div>
        </div>
        <article class="radar-body">
          <div class="radar-topline">
            <a class="radar-repo" href="{{ r.repo_url }}" target="_blank" rel="noopener noreferrer">{{ r.repo }}</a>
            <span class="radar-date">{{ r.date }}</span>
          </div>
          <h2><a href="{{ r.repo_url }}" target="_blank" rel="noopener noreferrer">{{ r.name }}</a></h2>
          <p class="radar-summary">{{ r.summary }}</p>
          <div class="radar-metrics" aria-label="Repository metrics">
            <div class="radar-metric">
              <span class="metric-label">Stars</span>
              <span class="metric-value">{{ "{:,}".format(r.stars or 0) }}</span>
            </div>
            <div class="radar-metric">
              <span class="metric-label">Created</span>
              <span class="metric-value">{{ (r.created_at or "n/a")[:10] }}</span>
            </div>
            <div class="radar-metric">
              <span class="metric-label">Updated</span>
              <span class="metric-value">{{ (r.pushed_at or "n/a")[:10] }}</span>
            </div>
          </div>
          <div class="radar-grid">
            <div class="radar-box wide">
              <span class="label">Feature outline / CATR</span>
              <ul class="radar-outline">
                {% if r.feature_outline %}
                {% for item in r.feature_outline %}
                <li><b>{{ item.lens }}</b> {{ item.text }}</li>
                {% endfor %}
                {% else %}
                <li><b>Capability</b> {{ r.summary }}</li>
                <li><b>Activation</b> {{ r.developer_use_case }}</li>
                <li><b>Trade-off</b> {{ (r.risk_notes or ["特記事項なし"]) | join(" / ") }}</li>
                <li><b>Reuse</b> {{ (r.ai_pulse_fit or []) | join(" / ") or "適用先は評価中" }}</li>
                {% endif %}
              </ul>
            </div>
            <div class="radar-box">
              <span class="label">Adoption reason / Ops fit</span>
              <p>{{ r.adoption_reason or r.developer_use_case }}</p>
            </div>
            <div class="radar-box">
              <span class="label">License / cost</span>
              <p>{{ r.pricing_or_license }}</p>
            </div>
            <div class="radar-box">
              <span class="label">Difficulty</span>
              <p>{{ r.implementation_difficulty }}</p>
            </div>
            <div class="radar-box">
              <span class="label">Risks</span>
              <p>{{ (r.risk_notes or ["特記事項なし"]) | join(" / ") }}</p>
            </div>
            <div class="radar-box wide">
              <span class="label">Adoption trigger</span>
              <ul class="radar-signals">
                {% for s in r.signals or [] %}
                <li><b>{{ s.source }}</b> <a href="{{ s.url or r.repo_url }}" target="_blank" rel="noopener noreferrer">{{ s.title or r.repo }}</a></li>
                {% endfor %}
              </ul>
            </div>
          </div>
          <div class="radar-tags" aria-label="AI-Pulse 適用候補">
            {% for fit in r.ai_pulse_fit or [] %}<span>{{ fit }}</span>{% endfor %}
            {% for fit in r.ideastash_fit_public or [] %}<span>{{ fit }}</span>{% endfor %}
          </div>
          <div class="radar-stats">
            <span>fork {{ r.forks }}</span>
            <span>{{ r.language or "language n/a" }}</span>
            <span>{{ r.license or "license n/a" }}</span>
          </div>
        </article>
      </li>
      {% endfor %}
    </ol>
    {% endif %}
  </main>
  {% include "_footer.html.j2" %}
</body>
</html>

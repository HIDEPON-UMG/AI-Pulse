<!DOCTYPE html>
<html lang="ja">
<head>
<title>AI-Pulse — カルテ一覧</title>
{% include "_head.html.j2" %}
<style>
.ki-head { padding: var(--s-32) 0 var(--s-24); border-bottom: 1px solid var(--border); }
.ki-head .kicker { display: flex; align-items: center; gap: var(--s-16); flex-wrap: wrap; }
.ki-head h1 {
  font-weight: var(--w-bold); font-size: clamp(28px, 4.2vw, 44px); letter-spacing: -0.02em;
  margin: var(--s-16) 0 var(--s-8); text-wrap: balance;
}
.ki-head .lead { color: var(--fg-sub); max-width: 64ch; margin: 0; font-size: var(--t-sm); }

/* グループ（カテゴリ別セクション） */
.ki-group { padding: var(--s-32) 0 var(--s-16); border-bottom: 1px solid var(--border-soft); }
.ki-group:last-child { border-bottom: 0; }
.ki-group-head { display: flex; align-items: baseline; gap: var(--s-16); flex-wrap: wrap; margin-bottom: var(--s-16); }
.ki-group-head .gly {
  font-size: 22px; line-height: 1; color: var(--cat); font-weight: 700;
  display: inline-flex; align-items: center; justify-content: center;
  width: 32px; height: 32px; border-radius: var(--r-sm);
  background: color-mix(in oklab, var(--cat) 18%, transparent);
}
.ki-group-head h2 {
  font-family: var(--font-head); font-weight: var(--w-bold); font-size: 20px;
  margin: 0; color: var(--fg); letter-spacing: -0.01em;
}
.ki-group-head .count {
  font-family: var(--font-mono); font-size: var(--t-label); color: var(--fg-mute);
  letter-spacing: 0.08em;
}

/* カード grid */
.ki-cards {
  display: grid; gap: var(--s-16);
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
}
.ki-card {
  position: relative;
  display: flex; flex-direction: column; gap: 8px;
  min-height: 170px;
  padding: var(--s-16); background: var(--bg-elev);
  border: 1px solid var(--border); border-left: 2px solid var(--cat);
  border-radius: var(--r-sm); text-decoration: none; color: inherit;
  overflow: hidden;
  transition: background .15s, border-color .15s, transform .15s;
}
.ki-card:hover {
  background: var(--bg-elev-2); border-color: color-mix(in oklab, var(--cat) 55%, var(--border));
  transform: translateY(-1px);
}
.ki-card h3 {
  /* (2026-06-04) 17px → clamp(26px,3vw,34px) に拡大。カードの主役を h3 にする。
     line-height 1.25 でディスクリプタも詰まりすぎず可読性確保。 */
  font-family: var(--font-head); font-weight: var(--w-bold);
  font-size: clamp(26px, 3vw, 34px);
  margin: var(--s-4) 0 var(--s-4); color: var(--fg);
  letter-spacing: -0.02em; line-height: 1.25;
}
.ki-card .title-row {
  display: block;
}
.ki-card .card-logo {
  position: absolute; right: var(--s-16); bottom: var(--s-16);
  width: 64px; height: 64px; object-fit: contain;
  background: color-mix(in oklab, var(--fg) 6%, transparent);
  border: 1px solid var(--border); border-radius: var(--r-sm);
  padding: 8px; opacity: .88; pointer-events: none;
  z-index: 0;
}
.ki-card > *:not(.card-logo) { position: relative; z-index: 1; }
.ki-card:hover h3 { color: var(--cat); }

/* (2026-06-04) カードの「直近アップデート」を 2 種並列で。位置はカード下方 (meta 直上)。
   .upd.feed  = フィード(events 最新由来)         → accent (Claude Orange) で「動的な活発さ」を表現
   .upd.karte = カルテ本体(entity.snapshot_date由来) → var(--cat) (カテゴリ色) で「このレンズの鮮度」を表現
   各々独立に fresh (7 日以内) を判定して強調。 */
.ki-card .upd-row {
  display: flex; flex-wrap: wrap; gap: 6px;
  margin-top: 6px;
}
.ki-card .upd {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: var(--font-mono); font-size: 11.5px; line-height: 1;
  padding: 4px 9px; border-radius: var(--r-sm);
  color: var(--fg-sub); letter-spacing: 0.02em;
}
.ki-card .upd .kind {
  font-family: var(--font-head); font-size: 10.5px; font-weight: 700;
  letter-spacing: 0.06em;
}
.ki-card .upd .dot { width: 6px; height: 6px; border-radius: 50%; flex: none; }
.ki-card .upd .abs { font-size: 10px; opacity: .85; }

/* feed: accent (Claude Orange) */
.ki-card .upd.feed {
  background: color-mix(in oklab, var(--accent) 7%, var(--bg-elev-2));
  border: 1px solid color-mix(in oklab, var(--accent) 24%, var(--border));
}
.ki-card .upd.feed .kind { color: color-mix(in oklab, var(--accent) 72%, var(--fg-mute)); }
.ki-card .upd.feed .dot { background: color-mix(in oklab, var(--accent) 55%, var(--fg-mute)); }
.ki-card .upd.feed .abs { color: color-mix(in oklab, var(--accent) 38%, var(--fg-mute)); }
.ki-card .upd.feed.fresh {
  background: color-mix(in oklab, var(--accent) 20%, var(--bg-elev));
  color: var(--accent);
  border-color: color-mix(in oklab, var(--accent) 45%, var(--border));
  font-weight: 700;
}
.ki-card .upd.feed.fresh .kind { color: color-mix(in oklab, var(--accent) 82%, var(--fg-sub)); }
.ki-card .upd.feed.fresh .dot { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
.ki-card .upd.feed.fresh .abs { color: color-mix(in oklab, var(--accent) 60%, var(--fg-sub)); }

/* karte: カテゴリ色 (var(--cat)) */
.ki-card .upd.karte {
  background: color-mix(in oklab, var(--cat) 7%, var(--bg-elev-2));
  border: 1px solid color-mix(in oklab, var(--cat) 24%, var(--border));
}
.ki-card .upd.karte .kind { color: color-mix(in oklab, var(--cat) 72%, var(--fg-mute)); }
.ki-card .upd.karte .dot { background: color-mix(in oklab, var(--cat) 55%, var(--fg-mute)); }
.ki-card .upd.karte .abs { color: color-mix(in oklab, var(--cat) 38%, var(--fg-mute)); }
.ki-card .upd.karte.fresh {
  background: color-mix(in oklab, var(--cat) 20%, var(--bg-elev));
  color: var(--cat);
  border-color: color-mix(in oklab, var(--cat) 45%, var(--border));
  font-weight: 700;
}
.ki-card .upd.karte.fresh .kind { color: color-mix(in oklab, var(--cat) 82%, var(--fg-sub)); }
.ki-card .upd.karte.fresh .dot { background: var(--cat); box-shadow: 0 0 6px var(--cat); }
.ki-card .upd.karte.fresh .abs { color: color-mix(in oklab, var(--cat) 60%, var(--fg-sub)); }
.ki-card .pos {
  margin: 0; color: var(--fg-sub); font-size: 13px; line-height: 1.6;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.ki-card .meta {
  display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  margin-top: 4px; padding-right: 80px;
  font-family: var(--font-mono); font-size: 10.5px; color: var(--fg-mute);
}
.ki-card .meta .vendor { color: var(--fg-sub); }
.ki-card .meta .cat-mini {
  display: inline-flex; align-items: center; gap: 4px;
  color: var(--cat); font-weight: 500;
}

@media (max-width: 640px) {
  .ki-cards { grid-template-columns: 1fr; }
}
</style>
</head>
<body data-page="karte_index">

{% include "_header.html.j2" %}

<main class="app-main">
  <div class="wrap">
    <div class="ki-head">
      <div class="kicker"><span class="label">カルテ一覧 / KARTE INDEX</span></div>
      <h1>各サービス・モデルの分析カルテ</h1>
      <p class="lead">7 つのレンズ（カテゴリ）ごとに、注目サービス・モデル・規制を整理。気になるカードから個別カルテへ。<b style="color:var(--fg-sub);font-weight:500">全 {{ karte_total }} 件</b></p>
    </div>
  </div>

  <div class="wrap">
    {% for g in karte_index_groups %}
    <section class="ki-group" data-cat="{{ g.cat }}">
      <div class="ki-group-head">
        <span class="gly" aria-hidden="true">{{ g.glyph }}</span>
        <h2>{{ g.cat_label }}</h2>
        <span class="count">{{ "%02d"|format(g.cards|length) }} 件</span>
      </div>
      <div class="ki-cards">
        {% for it in g.cards %}
        <a class="ki-card" href="{{ it.href }}" data-cat="{{ it.cat }}">
          <div class="title-row">
            <h3>{{ it.name }}</h3>
          </div>
          <p class="pos">{{ it.positioning }}</p>
          <div class="upd-row">
            {% if it.feed_updated_rel %}
            <span class="upd feed{% if it.feed_updated_fresh %} fresh{% endif %}" title="フィード(直近ニュース) 最終 {{ it.feed_updated_abs }}">
              <span class="kind">📰 フィード</span>
              <span class="dot" aria-hidden="true"></span>{{ it.feed_updated_rel }}<span class="abs">{{ it.feed_updated_abs }}</span>
            </span>
            {% endif %}
            {% if it.karte_updated_rel %}
            <span class="upd karte{% if it.karte_updated_fresh %} fresh{% endif %}" title="カルテ本体 最終 {{ it.karte_updated_abs }}">
              <span class="kind">📋 カルテ</span>
              <span class="dot" aria-hidden="true"></span>{{ it.karte_updated_rel }}<span class="abs">{{ it.karte_updated_abs }}</span>
            </span>
            {% endif %}
          </div>
          <div class="meta">
            <span class="cat-mini">{{ it.glyph }} {{ it.cat_label }}</span>
            <span class="vendor">{{ it.vendor }}</span>
          </div>
          {% if it.logo and it.logo.path and it.logo.status != 'missing' %}<img class="service-logo card-logo" src="{{ it.logo.path }}" alt="{{ it.name }} logo" loading="lazy" decoding="async" />{% endif %}
        </a>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  </div>

  {% include "_footer.html.j2" %}
</main>

<script src="app.js"></script>
</body>
</html>

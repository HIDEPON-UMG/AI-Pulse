<header class="app-header">
  <a class="brand" href="index.html" aria-label="AI-Pulse ホーム">
    <svg class="logo" viewBox="0 0 32 32" width="40" height="40" aria-hidden="true">
      <rect x="1.5" y="1.5" width="29" height="29" rx="7.5" fill="var(--accent)"></rect>
      <!-- AI モチーフ: ニューラルのシナプス枝（パルス頂点から分岐） -->
      <path d="M12.5 9 L8.5 5.5 M16.5 23.5 L21.5 20" fill="none" stroke="#fff" stroke-width="1.2" stroke-linecap="round" opacity=".55"></path>
      <!-- パルス（心電図ライン） -->
      <path class="ekg" d="M4.5 16.5 H10 L12.5 9 L16.5 23.5 L20 16.5 H27.5" fill="none" stroke="#fff" stroke-width="2.4" stroke-linejoin="round" stroke-linecap="round"></path>
      <!-- AI モチーフ: パルス頂点のニューロン節点（中央を accent で抜く） -->
      <circle cx="8.5" cy="5.5" r="1.5" fill="#fff"></circle>
      <circle cx="21.5" cy="20" r="1.5" fill="#fff"></circle>
      <circle cx="12.5" cy="9" r="2.2" fill="#fff"></circle>
      <circle cx="16.5" cy="23.5" r="2.2" fill="#fff"></circle>
      <circle cx="12.5" cy="9" r="0.95" fill="var(--accent)"></circle>
      <circle cx="16.5" cy="23.5" r="0.95" fill="var(--accent)"></circle>
    </svg>
    <span class="name">AI<b>-</b>Pulse</span>
  </a>
  <nav class="app-nav">
    <a href="index.html"{% if page == 'feed' %} aria-current="page"{% endif %}>フィード</a>
    <a href="archive.html"{% if page == 'archive' %} aria-current="page"{% endif %}>アーカイブ</a>
    <a href="karte-index.html"{% if page in ('karte_index', 'karte') %} aria-current="page"{% endif %}>カルテ</a>
    <a href="repo-radar.html"{% if page == 'repo_radar' %} aria-current="page"{% endif %}>リポジトリ</a>
    <a href="buzz-posts.html"{% if page == 'buzzpost' %} aria-current="page"{% endif %}>BuzzPost</a>
  </nav>
  <span class="header-spacer"></span>
</header>

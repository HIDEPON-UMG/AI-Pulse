<!doctype html>
<html lang="ja">
<head>
  <title>BuzzPost — AI-Pulse</title>
  {% include "_head.html.j2" %}
  <style>
    .buzz-head { padding: var(--s-24) 0 var(--s-16); border-bottom: 1px solid var(--border); }
    .buzz-head h1 { margin: 18px 0 10px; font-size: clamp(30px, 4.8vw, 54px); line-height: 1.05; }
    .buzz-head .lead { max-width: 850px; color: var(--fg-sub); font-size: 16px; line-height: 1.8; }
    .buzz-meta { display:flex; flex-wrap:wrap; gap: 8px; margin-top: 14px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 12px; }
    .buzz-toolbar { position: sticky; top: var(--header-h); z-index: 20; display: grid; grid-template-columns: minmax(220px, 280px) minmax(140px, 180px) 1fr; gap: 18px; align-items: center; padding: 14px 0; background: color-mix(in oklch, var(--bg) 90%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-soft); }
    .buzz-search { min-height: 42px; border: 1px solid var(--border); background: var(--bg-elev); color: var(--fg); padding: 0 14px; font-family: var(--font-body); font-size: 14px; border-radius: var(--r-sm); }
    .buzz-search:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
    .buzz-sort { min-height: 42px; border: 1px solid var(--border); background: var(--bg-elev); color: var(--fg); padding: 0 12px; font-family: var(--font-mono); font-size: 12px; border-radius: var(--r-sm); }
    .buzz-sort:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
    .buzz-section-nav { display:flex; flex-wrap:wrap; gap: 10px; align-items:center; margin: 18px 0 6px; }
    .buzz-section-nav a { display:inline-flex; gap: 8px; align-items:center; min-height: 34px; padding: 0 12px; border: 1px solid var(--border); border-radius: var(--r-sm); background: var(--bg-elev); color: var(--fg); font-family: var(--font-mono); font-size: 12px; text-decoration:none; }
    .buzz-section-nav a:hover { border-color: var(--accent); color: var(--accent); }
    .buzz-section-nav small { color: var(--fg-mute); font-size: 11px; }
    .buzz-list-head { display:flex; justify-content: space-between; align-items:center; gap: 12px; margin: 26px 0 14px; }
    .buzz-list-head h2 { margin:0; font-size: 20px; }
    .buzz-list { list-style:none; max-width: 760px; margin:0 auto; padding:0; display:grid; gap: 22px; }
    .buzz-card { margin:0; }
    .x-embed-shell { display:block; padding: 0; background: transparent; border: 0; border-radius: 0; }
    .x-discord-embed { min-width:0; display:grid; gap: 10px; width:min(548px, 100%); margin:0 auto; padding: 14px 16px; background: #323339; border: 1px solid #454751; border-left: 4px solid var(--cat, var(--accent)); border-radius: var(--r-sm); box-shadow: 0 8px 18px rgba(0,0,0,.16); }
    .x-discord-score { display:flex; flex-wrap:wrap; gap: 8px; align-items:center; color:#c9d1dc; font-family: var(--font-mono); font-size: 11px; }
    .x-discord-score b { color: var(--cat, var(--accent)); font-size: 36px; line-height: 1; }
    .x-discord-score .cat-badge { width:auto; }
    .x-oembed-frame { width:min(550px, 100%); margin: 2px auto 0; overflow:hidden; background:#000; border-radius: 12px; }
    .x-oembed-frame .twitter-tweet { margin:0 !important; }
    .x-oembed-frame iframe { display:block !important; max-width:100% !important; margin:0 !important; background:#000 !important; }
    .x-translation-toggle { width:max-content; border:0; background:transparent; color:#38bdf8; padding:0; font-family: 'Meiryo UI', Meiryo, 'Yu Gothic UI', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 12px; font-weight:700; cursor:pointer; }
    .x-translation-toggle:hover { text-decoration:underline; }
    .x-discord-text { margin:0; color:var(--fg); font-family: 'Meiryo UI', Meiryo, 'Yu Gothic UI', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 14px; line-height: 1.55; white-space:pre-wrap; overflow-wrap:anywhere; }
    .x-discord-text[hidden] { display:none; }
    .x-discord-text-link { color:#38bdf8; text-decoration:none; }
    .x-discord-text-link:hover { text-decoration:underline; }
    .x-link-preview { display:grid; grid-template-columns: 132px minmax(0, 1fr); gap: 10px; align-items:stretch; overflow:hidden; border:1px solid #454751; border-radius: var(--r-sm); background:#292b31; color:var(--fg); text-decoration:none; }
    .x-link-preview img { display:block; width:100%; height:100%; min-height:88px; object-fit:cover; background:#25272d; }
    .x-link-preview-body { min-width:0; padding: 10px 10px 10px 0; display:flex; flex-direction:column; justify-content:center; gap:4px; font-family:'Meiryo UI', Meiryo, 'Yu Gothic UI', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
    .x-link-preview-title { color:#f2f5f9; font-size:13px; font-weight:700; line-height:1.35; overflow-wrap:anywhere; }
    .x-link-preview-site { color:#9aa4b2; font-family:var(--font-mono); font-size:11px; overflow-wrap:anywhere; }
    .x-discord-media-grid { display:grid; gap: 6px; grid-template-columns: repeat(2, minmax(0, 1fr)); overflow:hidden; border-radius: var(--r-sm); }
    .x-discord-media-grid img { display:block; width:100%; aspect-ratio: 16 / 10; object-fit: cover; background:#25272d; border: 1px solid #454751; }
    .x-discord-media-grid img:first-child:nth-last-child(1) { grid-column: 1 / -1; aspect-ratio: 16 / 9; }
    .x-discord-link { display:block; color:var(--accent); font-family: var(--font-mono); font-size: 12px; line-height: 1.45; overflow-wrap:anywhere; text-decoration:none; }
    .x-discord-link:hover { text-decoration: underline; }
    .x-discord-foot { display:flex; flex-wrap:wrap; gap: 10px; color:#9aa4b2; font-family: var(--font-mono); font-size: 11px; }
    .cat-badge { width:max-content; }
    .buzz-tags { display:grid; gap: 10px; min-width:0; }
    .buzz-tag { display:block; min-width:0; padding: 8px 10px; border: 1px solid color-mix(in oklch, var(--cat, var(--accent)) 34%, var(--border)); color: var(--fg-sub); font-family: var(--font-mono); font-size: 11px; line-height: 1.45; border-radius: var(--r-sm); overflow-wrap:anywhere; }
    .buzz-tag strong { display:block; color: var(--fg-mute); font-size: 10px; letter-spacing:.08em; text-transform:uppercase; margin-bottom: 4px; }
    .buzz-open { display:inline-flex; align-items:center; justify-content:center; color: var(--accent); text-decoration:none; border: 1px solid color-mix(in oklch, var(--accent) 45%, var(--border)); padding: 9px 11px; border-radius: var(--r-sm); font-family: var(--font-mono); font-size: 12px; }
    .buzz-empty { margin-top: 24px; padding: 24px; background: var(--bg-elev); border: 1px solid var(--border); color: var(--fg-sub); }
    .buzz-empty strong { color: var(--fg); }
    .buzz-empty-grid { display:grid; grid-template-columns: repeat(4, minmax(120px, 1fr)); gap: 10px; margin-top: 16px; }
    .buzz-empty-stat { border: 1px solid var(--border-soft); padding: 12px; border-radius: var(--r-sm); font-family: var(--font-mono); }
    .buzz-empty-stat b { display:block; color: var(--fg); font-size: 22px; }
    .buzz-empty-note { margin-top: 14px; line-height: 1.7; }
    @media (max-width: 820px) {
      .buzz-toolbar { grid-template-columns: 1fr; }
      .buzz-toolbar .chip-row { width:100%; max-width:none; margin:0; padding:0 2px 2px; flex-wrap:nowrap; overflow-x:auto; overflow-y:hidden; -webkit-overflow-scrolling:touch; scrollbar-width:none; }
      .buzz-toolbar .chip-row::-webkit-scrollbar { display:none; }
      .buzz-toolbar .chip-row .chip { flex:0 0 auto; }
      .buzz-list { max-width: 100%; }
      .x-discord-embed { width:100%; }
      .buzz-empty-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
  </style>
</head>
<body data-page="buzzpost">
  {% include "_header.html.j2" %}
  <main class="app-main">
    <div class="wrap">
      <section class="buzz-head">
        <div class="kicker">
          <span class="dateline"><span class="live-dot"></span> {{ ref_date_label }}</span>
          <span class="label">BuzzPost / COMMUNITY SIGNAL</span>
          <span class="count-pill"><b data-count>{{ "%02d"|format(buzzpost_count) }}</b> posts</span>
        </div>
        <h1>生成AIコミュニティのバズ投稿</h1>
        <p class="lead">X 上で話題化しているモデル、AIエディタ、エージェント、生成メディア関連の投稿を日次で集め、ニュース化前の関心のうねりを確認する観測フィードです。</p>
        <div class="buzz-meta">
          <span>latest {{ buzzpost_latest or "未実行" }}</span>
          <span>source: X RSS</span>
          <span>read-only observation layer</span>
        </div>
      </section>

      <section class="buzz-toolbar" aria-label="BuzzPost controls">
        <input class="buzz-search" type="search" data-search placeholder="post / query / category を検索" aria-label="BuzzPost 検索" />
        <select class="buzz-sort" data-sort="score_desc" aria-label="並び替え">
          <option value="score_desc" selected>Score high</option>
          <option value="date_desc">Latest</option>
        </select>
        <div class="chip-row" data-filter-bar aria-label="カテゴリフィルタ">
          <button class="chip all" type="button" aria-pressed="true">All</button>
          {% for c in buzzpost_categories %}
          <button class="chip" type="button" data-cat="{{ c.cat }}" aria-pressed="true">
            <span class="gly">{{ c.glyph }}</span>{{ c.cat_label }}
          </button>
          {% endfor %}
        </div>
      </section>

      {% if not buzz_posts %}
      <section class="buzz-empty">
        {% set s = buzzpost_stats or {} %}
        {% if s.candidate_count %}
          <strong>収集は成功しています。</strong>ただし、現在の掲載閾値を超えた投稿がありません。
          <div class="buzz-empty-grid">
            <div class="buzz-empty-stat"><span>候補</span><b>{{ s.candidate_count }}</b><small>件</small></div>
            <div class="buzz-empty-stat"><span>掲載</span><b>{{ s.collected }}</b><small>件</small></div>
            <div class="buzz-empty-stat"><span>閾値未満</span><b>{{ s.dropped_threshold }}</b><small>件</small></div>
            <div class="buzz-empty-stat"><span>取得状態</span><b>{{ "注意" if s.degraded else "正常" }}</b><small>RSS</small></div>
          </div>
          <p class="buzz-empty-note">掲載条件は <strong>absolute_score ≥ {{ s.min_absolute_score }}</strong> または <strong>velocity_score ≥ {{ "%.1f"|format(s.min_velocity_score) }}/h</strong> です。0点や弱い反応の投稿は、候補に入っても feed には表示しません。</p>
        {% else %}
          <strong>BuzzPost はまだ収集結果を持っていません。</strong>日次バッチが X RSS を生成すると、このページに生成AIコミュニティの話題投稿が表示されます。
          <p class="buzz-empty-note">未実行、RSS出力なし、または取得失敗の可能性があります。日次バッチの BuzzPost collect ログを確認してください。</p>
        {% endif %}
      </section>
      {% else %}
      <nav class="buzz-section-nav" aria-label="BuzzPost sections">
        {% for section in buzzpost_sections %}
        <a href="#{{ section.id }}">{{ section.nav_label }} <small>{{ section.rows|length }} posts</small></a>
        {% endfor %}
      </nav>
      {% for section in buzzpost_sections %}
      <section id="{{ section.id }}" data-date-group>
        <div class="buzz-list-head">
          <h2>{{ section.title }}</h2>
          <span class="count-pill">{{ "%02d"|format(section.rows|length) }} posts</span>
        </div>
        <ol class="buzz-list" data-buzz-list>
          {% for p in section.rows %}
          <li class="buzz-card" data-filter-item data-cat="{{ p.cat }}" data-score="{{ p.score }}" data-published="{{ p.published_at or "" }}">
            <article class="x-embed-shell">
              <div class="x-discord-embed">
                <div class="x-discord-score">
                  <b>{{ p.score }}</b>
                  <span>BUZZ SCORE</span>
                  <span>abs {{ p.absolute_score or 0 }}</span>
                  <span>rel {{ p.relative_score or 0 }}</span>
                  <span>vel {{ "%.1f"|format(p.velocity_score or 0) }}/h</span>
                  <span class="cat-badge"><span class="gly">{{ p.glyph }}</span>{{ p.cat_label }}</span>
                </div>
                {% if p.x_embed_html %}
                  <div class="x-oembed-frame">
                    {{ p.x_embed_html }}
                  </div>
                {% elif p.translated %}
                <button class="x-translation-toggle" type="button" data-translation-toggle aria-expanded="false">
                  <span data-show-original>原文を表示</span><span data-show-translation hidden>翻訳を表示</span>
                </button>
                <p class="x-discord-text" data-translated-text>{{ p.text_html }}</p>
                <p class="x-discord-text" data-original-text hidden>{{ p.text_original_html }}</p>
                {% else %}
                <p class="x-discord-text">{{ p.text_html }}</p>
                {% endif %}
                {% if not p.x_embed_html %}
                {% if p.media_urls %}
                <div class="x-discord-media-grid">
                  {% for url in p.media_urls[:4] %}
                  <img src="{{ url }}" alt="" loading="lazy" referrerpolicy="no-referrer" />
                  {% endfor %}
                </div>
                {% endif %}
                {% for preview in p.link_previews[:1] %}
                <a class="x-link-preview" href="{{ preview.url }}" target="_blank" rel="noopener noreferrer">
                  <img src="{{ preview.image_url }}" alt="" loading="lazy" referrerpolicy="no-referrer" />
                  <span class="x-link-preview-body">
                    {% if preview.title %}<span class="x-link-preview-title">{{ preview.title }}</span>{% endif %}
                    <span class="x-link-preview-site">{{ preview.site_name or preview.url }}</span>
                  </span>
                </a>
                {% endfor %}
                <a class="x-discord-link" href="{{ p.post_url }}" target="_blank" rel="noopener noreferrer">{{ p.post_url }} →</a>
                <div class="x-discord-foot">
                  <span>{{ p.published_at or "time n/a" }}</span>
                  <span>{{ p.cat_label }}</span>
                </div>
                {% endif %}
              </div>
            </article>
          </li>
          {% endfor %}
        </ol>
      </section>
      {% endfor %}
      <p class="empty" style="display:none;">条件に一致する BuzzPost はありません。</p>
      {% endif %}
    </div>
  </main>
  {% include "_footer.html.j2" %}
  {% if buzz_posts|selectattr("x_embed_html")|list %}
  <script async src="https://platform.x.com/widgets.js" charset="utf-8"></script>
  {% endif %}
  <script>
    document.querySelectorAll('[data-translation-toggle]').forEach(function (button) {
      button.addEventListener('click', function () {
        var card = button.closest('.x-discord-embed');
        if (!card) return;
        var translated = card.querySelector('[data-translated-text]');
        var original = card.querySelector('[data-original-text]');
        var showOriginal = button.querySelector('[data-show-original]');
        var showTranslation = button.querySelector('[data-show-translation]');
        if (!translated || !original || !showOriginal || !showTranslation) return;
        var originalHidden = original.hasAttribute('hidden');
        if (originalHidden) {
          translated.setAttribute('hidden', '');
          original.removeAttribute('hidden');
          showOriginal.setAttribute('hidden', '');
          showTranslation.removeAttribute('hidden');
          button.setAttribute('aria-expanded', 'true');
        } else {
          original.setAttribute('hidden', '');
          translated.removeAttribute('hidden');
          showTranslation.setAttribute('hidden', '');
          showOriginal.removeAttribute('hidden');
          button.setAttribute('aria-expanded', 'false');
        }
      });
    });
    function sortBuzzPosts(mode) {
      var lists = Array.from(document.querySelectorAll('[data-buzz-list]'));
      if (!lists.length) return;
      var scoreOf = function (item) {
        return Number(item.dataset.score || 0);
      };
      lists.forEach(function (list) {
        var items = Array.from(list.querySelectorAll('[data-filter-item]'));
        items.sort(function (a, b) {
          if (mode === 'date_desc') {
            return String(b.dataset.published || '').localeCompare(String(a.dataset.published || ''));
          }
          return scoreOf(b) - scoreOf(a);
        });
        items.forEach(function (item) {
          list.appendChild(item);
        });
      });
      if (window.twttr && window.twttr.widgets) {
        lists.forEach(function (list) {
          window.twttr.widgets.load(list);
        });
      }
    }
    var sortControl = document.querySelector('[data-sort]');
    if (sortControl) {
      sortControl.addEventListener('change', function () {
        sortControl.dataset.sort = sortControl.value;
        sortBuzzPosts(sortControl.value);
      });
      sortBuzzPosts(sortControl.value);
    }
  </script>
</body>
</html>

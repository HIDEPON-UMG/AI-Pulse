<!doctype html>
<html lang="ja">
<head>
  <title>BuzzPost — AI-Pulse</title>
  {% include "_head.html.j2" %}
  <style>
    .buzz-head { padding: var(--s-24) 0 var(--s-16); border-bottom: 1px solid var(--border); }
    .buzz-head h1 { margin: 18px 0 10px; font-size: clamp(30px, 4.8vw, 54px); line-height: 1.05; }
    .buzz-head .lead { max-width: 850px; color: var(--fg-sub); font-size: 16px; line-height: 1.8; }
    .buzz-meta { display:flex; flex-wrap:wrap; gap: 8px; margin-top: 14px; color: var(--fg-mute); font-family: var(--font-mono); font-size: 12px; }
    .buzz-toolbar { position: sticky; top: var(--header-h); z-index: 20; display: grid; grid-template-columns: minmax(220px, 280px) 1fr; gap: 18px; align-items: center; padding: 14px 0; background: color-mix(in oklch, var(--bg) 90%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-soft); }
    .buzz-search { min-height: 42px; border: 1px solid var(--border); background: var(--bg-elev); color: var(--fg); padding: 0 14px; font-family: var(--font-body); font-size: 14px; border-radius: var(--r-sm); }
    .buzz-search:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
    .buzz-list-head { display:flex; justify-content: space-between; align-items:center; gap: 12px; margin: 26px 0 14px; }
    .buzz-list-head h2 { margin:0; font-size: 20px; }
    .buzz-list { list-style:none; margin:0; padding:0; display:grid; gap: 18px; }
    .buzz-card { margin:0; }
    .x-embed-shell { display:grid; grid-template-columns: 148px minmax(0, 1fr) 210px; gap: 22px; align-items: stretch; padding: 18px; background: var(--bg-elev); border: 1px solid var(--border); border-left: 4px solid var(--cat, var(--accent)); border-radius: var(--r-sm); }
    .buzz-score { font-family: var(--font-mono); color: var(--cat, var(--accent)); padding-top: 8px; }
    .buzz-score b { display:block; font-size: 34px; line-height: 1; font-weight: 800; }
    .buzz-score span { display:block; margin-top: 7px; font-size: 10px; letter-spacing: .12em; color: var(--fg-mute); text-transform: uppercase; }
    .buzz-score small { display:block; margin-top: 16px; color: var(--fg-mute); font-size: 11px; line-height: 1.7; }
    .x-embed-card { min-width:0; display:grid; gap: 12px; }
    .x-embed-card .twitter-tweet { width: 100% !important; max-width: 640px !important; margin: 0 !important; color-scheme: dark; }
    .x-embed-card iframe { border-radius: var(--r-sm) !important; }
    .x-embed-fallback { padding: 18px 20px; background: color-mix(in oklch, var(--bg) 72%, var(--bg-elev)); border: 1px solid var(--border-soft); border-radius: var(--r-sm); }
    .x-embed-fallback p { margin: 0 0 14px; white-space: pre-wrap; overflow-wrap: anywhere; color: var(--fg); line-height: 1.75; font-size: 15px; }
    .x-embed-fallback a { color: var(--accent); text-decoration: none; border-bottom: 1px solid color-mix(in oklch, var(--accent) 45%, transparent); font-family: var(--font-mono); font-size: 12px; overflow-wrap: anywhere; }
    .buzz-meta-rail { display:flex; flex-direction:column; justify-content:space-between; gap: 18px; min-width:0; }
    .cat-badge { width:max-content; }
    .buzz-tags { display:flex; flex-direction:column; gap: 10px; }
    .buzz-tag { display:block; min-width:0; padding: 8px 10px; border: 1px solid color-mix(in oklch, var(--cat, var(--accent)) 34%, var(--border)); color: var(--fg-sub); font-family: var(--font-mono); font-size: 11px; line-height: 1.45; border-radius: var(--r-sm); overflow-wrap:anywhere; }
    .buzz-tag strong { display:block; color: var(--fg-mute); font-size: 10px; letter-spacing:.08em; text-transform:uppercase; margin-bottom: 4px; }
    .buzz-open { display:inline-flex; align-items:center; justify-content:center; color: var(--accent); text-decoration:none; border: 1px solid color-mix(in oklch, var(--accent) 45%, var(--border)); padding: 9px 11px; border-radius: var(--r-sm); font-family: var(--font-mono); font-size: 12px; }
    .buzz-empty { margin-top: 24px; padding: 24px; background: var(--bg-elev); border: 1px solid var(--border); color: var(--fg-sub); }
    .buzz-empty strong { color: var(--fg); }
    .buzz-empty-grid { display:grid; grid-template-columns: repeat(4, minmax(120px, 1fr)); gap: 10px; margin-top: 16px; }
    .buzz-empty-stat { border: 1px solid var(--border-soft); padding: 12px; border-radius: var(--r-sm); font-family: var(--font-mono); }
    .buzz-empty-stat b { display:block; color: var(--fg); font-size: 22px; }
    .buzz-empty-note { margin-top: 14px; line-height: 1.7; }
    @media (max-width: 820px) {
      .buzz-toolbar { grid-template-columns: 1fr; }
      .x-embed-shell { grid-template-columns: 1fr; }
      .buzz-tags { flex-direction: row; flex-wrap: wrap; }
      .buzz-tag { flex: 1 1 180px; }
      .buzz-score b { font-size: 30px; }
      .buzz-empty-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
  </style>
</head>
<body data-page="buzzpost">
  {% include "_header.html.j2" %}
  <main class="app-main">
    <div class="wrap">
      <section class="buzz-head">
        <div class="kicker">
          <span class="dateline"><span class="live-dot"></span> {{ ref_date_label }}</span>
          <span class="label">BuzzPost / COMMUNITY SIGNAL</span>
          <span class="count-pill"><b data-count>{{ "%02d"|format(buzzpost_count) }}</b> posts</span>
        </div>
        <h1>生成AIコミュニティのバズ投稿</h1>
        <p class="lead">X 上で話題化しているモデル、AIエディタ、エージェント、生成メディア関連の投稿を日次で集め、ニュース化前の関心のうねりを確認する観測フィードです。</p>
        <div class="buzz-meta">
          <span>latest {{ buzzpost_latest or "未実行" }}</span>
          <span>source: X RSS</span>
          <span>read-only observation layer</span>
        </div>
      </section>

      <section class="buzz-toolbar" aria-label="BuzzPost controls">
        <input class="buzz-search" type="search" data-search placeholder="post / query / category を検索" aria-label="BuzzPost 検索" />
        <div class="chip-row" data-filter-bar aria-label="カテゴリフィルタ">
          <button class="chip all" type="button" aria-pressed="true">All</button>
          {% for c in buzzpost_categories %}
          <button class="chip" type="button" data-cat="{{ c.cat }}" aria-pressed="true">
            <span class="gly">{{ c.glyph }}</span>{{ c.cat_label }}
          </button>
          {% endfor %}
        </div>
      </section>

      {% if not buzz_posts %}
      <section class="buzz-empty">
        {% set s = buzzpost_stats or {} %}
        {% if s.candidate_count %}
          <strong>収集は成功しています。</strong>ただし、現在の掲載閾値を超えた投稿がありません。
          <div class="buzz-empty-grid">
            <div class="buzz-empty-stat"><span>候補</span><b>{{ s.candidate_count }}</b><small>件</small></div>
            <div class="buzz-empty-stat"><span>掲載</span><b>{{ s.collected }}</b><small>件</small></div>
            <div class="buzz-empty-stat"><span>閾値未満</span><b>{{ s.dropped_threshold }}</b><small>件</small></div>
            <div class="buzz-empty-stat"><span>取得状態</span><b>{{ "注意" if s.degraded else "正常" }}</b><small>RSS</small></div>
          </div>
          <p class="buzz-empty-note">掲載条件は <strong>absolute_score ≥ {{ s.min_absolute_score }}</strong> または <strong>velocity_score ≥ {{ "%.1f"|format(s.min_velocity_score) }}/h</strong> です。0点や弱い反応の投稿は、候補に入っても feed には表示しません。</p>
        {% else %}
          <strong>BuzzPost はまだ収集結果を持っていません。</strong>日次バッチが X RSS を生成すると、このページに生成AIコミュニティの話題投稿が表示されます。
          <p class="buzz-empty-note">未実行、RSS出力なし、または取得失敗の可能性があります。日次バッチの BuzzPost collect ログを確認してください。</p>
        {% endif %}
      </section>
      {% else %}
      <div class="buzz-list-head">
        <h2>本日の観測ポスト</h2>
        <span class="count-pill"><b data-count>{{ "%02d"|format(buzzpost_count) }}</b> / {{ "%02d"|format(buzzpost_count) }} 件を表示</span>
      </div>
      <ol class="buzz-list" data-buzz-list>
        {% for p in buzz_posts %}
        <li class="buzz-card" data-filter-item data-cat="{{ p.cat }}" data-score="{{ p.score }}">
          <article class="x-embed-shell">
            <div class="buzz-score">
              <b>{{ p.score }}</b>
              <span>BUZZ SCORE</span>
              <small>{{ p.date }}<br>{{ p.published_at or "time n/a" }}</small>
            </div>
            <div class="x-embed-card">
              <blockquote class="twitter-tweet" data-theme="dark" data-dnt="true">
                <p lang="ja" dir="auto">{{ p.text }}</p>
                <a href="{{ p.post_url }}">{{ p.post_url }}</a>
              </blockquote>
              <div class="x-embed-fallback" aria-label="X post fallback">
                <p>{{ p.text }}</p>
                <a href="{{ p.post_url }}" target="_blank" rel="noopener noreferrer">{{ p.post_url }} →</a>
              </div>
            </div>
            <aside class="buzz-meta-rail" aria-label="BuzzPost metadata">
              <span class="cat-badge"><span class="gly">{{ p.glyph }}</span>{{ p.cat_label }}</span>
              <div class="buzz-tags">
                <span class="buzz-tag"><strong>source</strong>{{ p.source }}</span>
                <span class="buzz-tag"><strong>query</strong>{{ p.source_query }}</span>
              </div>
              <a class="buzz-open" href="{{ p.post_url }}" target="_blank" rel="noopener noreferrer">ポストを開く →</a>
            </aside>
          </article>
        </li>
        {% endfor %}
      </ol>
      <p class="empty" style="display:none;">条件に一致する BuzzPost はありません。</p>
      {% endif %}
    </div>
  </main>
  {% include "_footer.html.j2" %}
  {% if buzz_posts %}
  <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
  {% endif %}
</body>
</html>

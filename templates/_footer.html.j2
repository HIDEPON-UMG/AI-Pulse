<footer class="app-foot">
  <div class="wrap">
    <nav class="foot-nav" aria-label="フッターナビゲーション">
      <a href="index.html"{% if page == 'feed' %} aria-current="page"{% endif %}>Feed</a>
      <a href="buzz-posts.html"{% if page == 'buzzpost' %} aria-current="page"{% endif %}>BuzzPost</a>
      <a href="karte-index.html"{% if page in ('karte_index', 'karte') %} aria-current="page"{% endif %}>Karte</a>
      <a href="repo-radar.html"{% if page == 'repo_radar' %} aria-current="page"{% endif %}>Repo</a>
      <a href="archive.html"{% if page == 'archive' %} aria-current="page"{% endif %}>Archive</a>
      <span class="foot-brand">AI<b>-</b>Pulse</span>
    </nav>
    {% if kartes %}
    <div class="foot-cats">
      <span class="k">カルテ</span>
      {% for k in kartes %}<a href="karte-{{ k.id }}.html">{{ k.name }}</a>{% endfor %}
    </div>
    {% endif %}
  </div>
</footer>

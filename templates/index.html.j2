<!DOCTYPE html>
<html lang="ja">
<head>
<title>AI-Pulse — 新着フィード</title>
{% include "_head.html.j2" %}
<style>
/* ---- Feed-specific ---- */
.feed-head { padding: var(--s-32) 0 var(--s-24); border-bottom: 1px solid var(--border); }
.feed-head .kicker { display: flex; align-items: center; gap: var(--s-16); flex-wrap: wrap; }
.feed-head h1 {
  font-weight: var(--w-bold); font-size: clamp(32px, 4.8vw, 54px); letter-spacing: -0.02em;
  margin: var(--s-16) 0 var(--s-8); text-wrap: balance;
}
/* News-Grasp 流の「行下半分マーカー」: 主語とカテゴリ名にだけ accent 色の太い下線を敷く。
   theme.css の全面塗り mark を override（specificity: 0,0,2,1 > 0,0,0,1）。
   60% の閾値で「文字の下 4 割」にゴム引きしたような視認性。色は accent token 経由。 */
.feed-head h1 mark {
  background: linear-gradient(180deg, transparent 60%, color-mix(in oklab, var(--accent) 38%, transparent) 60%);
  color: var(--fg); padding: 0 4px; border-radius: 0;
  -webkit-box-decoration-break: clone; box-decoration-break: clone;
}
.feed-head .lead { color: var(--fg-sub); max-width: 64ch; margin: 0; font-size: var(--t-sm); }
.dateline { font-family: var(--font-mono); font-size: var(--t-sm); color: var(--fg); }
.live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--imp-high); display: inline-block; box-shadow: 0 0 8px var(--imp-high); }
.count-pill {
  font-family: var(--font-mono); font-size: var(--t-label); color: var(--fg-mute);
  border: 1px solid var(--border); padding: 4px 9px; border-radius: var(--r-sm); white-space: nowrap;
}
.count-pill b { color: var(--accent); font-weight: var(--w-bold); }

/* feed list */
.feed { list-style: none; margin: 0; padding: var(--s-8) 0 0; }
.story {
  display: grid; grid-template-columns: 80px 200px 1fr;
  gap: var(--s-16) var(--s-24); align-items: start;
  padding: var(--s-24) var(--s-16); margin: 0 calc(var(--s-16) * -1);
  border-bottom: 1px solid var(--border-soft);
  border-left: 2px solid transparent;
  transition: background .16s, border-color .16s;
}
.story:hover {
  background: var(--bg-elev);
  border-left-color: var(--cat);
}
.story[data-href] { cursor: pointer; }
.story .score { padding-top: 2px; }
.story .score .num { font-family: var(--font-mono); font-weight: 700; font-size: 28px; line-height: 1; color: var(--cat); letter-spacing: -0.03em; font-variant-numeric: tabular-nums; }
.story .score .lbl { font-family: var(--font-mono); font-size: 9px; letter-spacing: .18em; color: var(--fg-mute); margin-top: 4px; }
.story .score .date { font-family: var(--font-mono); font-size: 11px; color: var(--fg-mute); margin-top: 12px; line-height: 1.35; }
.story .score .date span { display: block; font-size: 10px; margin-top: 1px; opacity: .8; }
/* サムネイル列 */
.story .thumb-col { display: flex; flex-direction: column; gap: 8px; }
.story .thumb {
  width: 100%; aspect-ratio: 16 / 10; object-fit: cover; display: block;
  background: var(--bg-elev-2); border: 1px solid var(--border); border-radius: var(--r-sm);
}
.story .thumb[src=""] { visibility: hidden; }
/* (2026-06-04) 関連カルテ抽象ラベルを廃し、実カルテ名を chip で並べる（複数対応・カテゴリ色） */
/* (2026-06-04 改) chip 単体ではカルテ名と分かりにくいため、上にラベル「関連カルテ」を付与。
   さらにユーザー要望でフォントを 2 回り (11px→15px) 拡大し padding も比例で広げて判読性を上げる。 */
.story .karte-wrap { display: flex; flex-direction: column; gap: 4px; align-items: flex-start; }
.story .karte-label {
  font-family: var(--font-mono); font-size: 9.5px; color: var(--fg-mute);
  letter-spacing: 0.12em; text-transform: uppercase; line-height: 1;
}
.story .karte-chips { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
.story .karte-chip {
  font-family: var(--font-mono); font-size: 15px; color: var(--cat);
  border: 1px solid color-mix(in oklab, var(--cat) 45%, transparent);
  padding: 6px 11px; border-radius: var(--r-sm);
  display: inline-flex; align-items: center; line-height: 1.2;
  transition: background .15s; white-space: nowrap; text-decoration: none;
}
.story .karte-chip:hover { background: color-mix(in oklab, var(--cat) 12%, transparent); }
.story .metrics { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
.story .metric { display: inline-flex; align-items: center; gap: 5px; font-family: var(--font-mono); font-size: 10.5px; color: var(--fg-sub); }
.story .metric b { font-weight: 500; color: var(--fg-mute); }
.story .metric .bars { display: inline-flex; gap: 2px; }
.story .metric .bars i { width: 4px; height: 11px; background: var(--border-strong); display: block; }
.story .metric[data-level="高"] .bars i { background: var(--mc); }
.story .metric[data-level="中"] .bars i:nth-child(-n+2) { background: var(--mc); }
.story .metric[data-level="低"] .bars i:nth-child(1) { background: var(--mc); }
.story .metric[data-level="高"] { --mc: var(--imp-high); }
.story .metric[data-level="中"] { --mc: var(--imp-mid); }
.story .metric[data-level="低"] { --mc: var(--imp-low); }
.story .body { min-width: 0; }
.story .meta-row { display: flex; align-items: center; gap: var(--s-16); flex-wrap: wrap; margin-bottom: var(--s-8); }
.story h2 {
  font-family: var(--font-head); font-weight: var(--w-bold); font-size: 25px;
  letter-spacing: -0.01em; line-height: 1.4; margin: 0 0 8px; color: var(--fg);
  text-wrap: pretty;
}
.story:hover h2 { color: var(--accent); }
.story .summary {
  margin: 0; color: var(--fg-sub); font-size: 17px; line-height: 1.75;
  display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
}
.story .src { display: inline-flex; align-items: center; gap: 6px; margin-top: 10px; font-family: var(--font-mono); font-size: var(--t-label); color: var(--fg-mute); flex-wrap: wrap; }
.story .src .tier { color: var(--cat); font-weight: var(--w-med); }

/* スマホ (< 600px): 2列(スコア+サムネイル) → 本文 の縦積み */
@media (max-width: 600px) {
  .story {
    grid-template-columns: 64px 1fr;
    grid-template-rows: auto auto;
    gap: var(--s-8) var(--s-8);
  }
  /* 1行目: スコア(左) + サムネイル(右) */
  .story .score { grid-column: 1; grid-row: 1; }
  .story .thumb-col { grid-column: 2; grid-row: 1; }
  /* 2行目: 本文(全幅) */
  .story .body { grid-column: 1 / -1; grid-row: 2; }
  .story .thumb { aspect-ratio: 16 / 9; }
  .story h2 { font-size: 18px; }
  .story .score .num { font-size: 22px; }
}

/* タブレット (600〜860px): スコア狭め・サムネイル縮小 */
@media (min-width: 601px) and (max-width: 860px) {
  .story { grid-template-columns: 64px 160px 1fr; }
}

/* lead feature (first story bigger) */
.story.feature { background: var(--bg-elev); border-left-color: var(--cat); border-radius: var(--r-sm); }
.story.feature h2 { font-size: 27px; }
.story.feature .thumb { aspect-ratio: 16 / 9; }
@media (max-width: 600px) { .story.feature { background: none; } }
/* search */
.search-row { max-width: var(--maxw); margin: 0 auto; padding: 11px var(--s-24) 0; }
.search { display: flex; align-items: center; gap: 9px; background: var(--bg-elev); border: 1px solid var(--border); border-radius: var(--r-sm); padding: 8px 12px; max-width: 480px; color: var(--fg-mute); transition: border-color .15s; }
.search:focus-within { border-color: var(--accent); color: var(--fg-sub); }
.search input { flex: 1; background: transparent; border: 0; outline: 0; color: var(--fg); font-family: var(--font-body); font-size: 14px; min-width: 0; }
.search input::placeholder { color: var(--fg-mute); }
.empty { display: none; padding: var(--s-48) 0; text-align: center; color: var(--fg-mute); font-family: var(--font-mono); font-size: var(--t-sm); }

/* (D) 箇条書きサマリ */
.story .summary-points { margin: 4px 0 0; padding: 0; list-style: none; }
.story .summary-points li { position: relative; padding-left: 1.1em; color: var(--fg-sub); font-size: var(--t-sm); line-height: 1.6; margin: 4px 0; }
.story .summary-points li::before { content: "—"; position: absolute; left: 0; color: var(--cat); }
/* (D) 3指標バーのホバー/フォーカスで判断根拠をツールチップ表示 */
.story .metric[data-tip] { position: relative; cursor: help; }
.story .metric[data-tip]:hover::after, .story .metric[data-tip]:focus-visible::after {
  content: attr(data-tip); position: absolute; left: 0; top: calc(100% + 7px); z-index: 30;
  width: max-content; max-width: 270px; white-space: normal;
  background: var(--bg-elev-2); border: 1px solid var(--border-strong); border-radius: var(--r-sm);
  padding: 8px 11px; font-family: var(--font-body); font-size: 12px; line-height: 1.6;
  color: var(--fg-sub); box-shadow: var(--shadow-1); pointer-events: none;
}
.story .metric[data-tip]:focus-visible { outline: 1px solid var(--accent); outline-offset: 2px; }
/* (C) カルテ更新バッジ */
.story .upd-badge { font-family: var(--font-mono); font-size: 8.5px; letter-spacing: .08em; font-weight: 700; color: var(--accent-fg); background: var(--accent); padding: 1px 5px; border-radius: 2px; margin-right: 5px; vertical-align: middle; }
/* (2) News-Grasp 流の本文強調 3 種を意味分けして視覚レイヤーを完全分離する:
   - **太字** (<b>): 一般強調（固有名・サービス名・組織名）。フォントウェイトのみで主張を最小化。
   - ==マーカー== (<mark>): 決定打となる結論・数値。下半分塗りで「ハイライト」感を強調（News-Grasp 風）。
   - __下線__ (<u>): 動作・出来事・採用・引用。波線下線で「アクション」感を出し、塗りと完全に差別化。
   3 種が同時に出ても視覚レイヤー（太字↔塗り↔下線）が違うため判別できる。 */
.story .summary-points b, .story .summary b { color: var(--fg); font-weight: 700; }
.story .summary-points u, .story .summary u {
  text-decoration: underline wavy;
  text-decoration-color: var(--cat);
  text-decoration-thickness: 1.5px;
  text-underline-offset: 3px;
  font-weight: 600;
}
.story .summary-points mark, .story .summary mark {
  background: linear-gradient(180deg, transparent 60%, color-mix(in oklab, var(--cat) 42%, transparent) 60%);
  color: var(--fg); padding: 0 3px; border-radius: 0;
  -webkit-box-decoration-break: clone; box-decoration-break: clone;
}
/* 節区切り (News-Grasp 流: 短い横線 + 英語スモールキャップス) を story 内のセクション境界に入れる。
   タイトル↓本文の上に SUMMARY、本文↓評価理由折りたたみの上に EVALUATE を置き、構造を視覚化する。
   色は category accent (cat) 経由、フォントは既存 .label と揃えた mono small-caps。 */
.story .sect-rule {
  display: flex; align-items: center; gap: var(--s-8);
  margin: var(--s-16) 0 var(--s-8);
}
.story .sect-rule .ln {
  display: block; flex: 0 0 auto;
  width: 28px; height: 1.5px; background: var(--cat); border-radius: 1px;
}
.story .sect-rule .lbl {
  font-family: var(--font-mono); font-size: 10.5px; font-weight: 600;
  letter-spacing: 0.16em; color: var(--cat); text-transform: uppercase;
}
/* (5) 判断理由トグル（デフォルト閉じ・クリックで開く。3指標バーのホバーtooltipは併存） */
.story .why { margin-top: 10px; }
.story .why > summary {
  cursor: pointer; display: inline-flex; align-items: center; gap: 6px; width: max-content;
  font-family: var(--font-mono); font-size: var(--t-label); color: var(--fg-mute);
  list-style: none; user-select: none; transition: color .15s;
}
.story .why > summary:hover { color: var(--cat); }
.story .why > summary::-webkit-details-marker { display: none; }
.story .why > summary .ic { display: inline-block; transition: transform .15s ease; }
.story .why[open] > summary .ic { transform: rotate(180deg); }
.story .why-list { margin: 8px 0 2px; display: grid; gap: 7px; border-left: 2px solid var(--border-strong); padding-left: var(--s-16); }
.story .why-list > div { display: grid; grid-template-columns: 36px 1fr; gap: var(--s-8); align-items: start; }
.story .why-list dt { font-family: var(--font-mono); font-size: 10.5px; color: var(--cat); padding-top: 2px; }
.story .why-list dd { margin: 0; font-size: 12.5px; line-height: 1.65; color: var(--fg-sub); }

/* (2026-06-04 ユーザー要件) 本文・判断理由を「カテゴリ色の薄背景＋左帯」で囲み読みやすくする。
   濃度は 7% 程度に抑えて fg-sub テキストとの読みやすさを担保（色混ざりで字が沈まないこと）。
   feature 記事の h2 も連動で 1 回り拡大し、要約箇条書きの本文サイズも 16px に上げる。 */
.story.feature h2 { font-size: 30px; }
.story .summary-points {
  background: color-mix(in oklab, var(--cat) 7%, transparent);
  border-left: 2px solid color-mix(in oklab, var(--cat) 45%, transparent);
  border-radius: var(--r-sm);
  padding: 12px 14px; margin-top: 8px;
}
.story .summary-points li { font-size: 16px; line-height: 1.7; color: var(--fg); margin: 5px 0; }
.story .summary {
  background: color-mix(in oklab, var(--cat) 7%, transparent);
  border-left: 2px solid color-mix(in oklab, var(--cat) 45%, transparent);
  border-radius: var(--r-sm);
  padding: 12px 14px; color: var(--fg);
}
/* 判断理由本体 (.why-list) は色混ざりを避けるため濃度を 5% に抑える（dt が cat 色 mono のため重なる） */
.story .why-list {
  background: color-mix(in oklab, var(--cat) 5%, transparent);
  border-left-color: color-mix(in oklab, var(--cat) 45%, transparent);
  border-radius: var(--r-sm);
  padding: 12px var(--s-16);
}
.story .why-list dd { color: var(--fg-sub); }
@media (max-width: 600px) {
  .story.feature h2 { font-size: 20px; }
  .story .summary-points { padding: 10px 12px; }
  .story .summary { padding: 10px 12px; }
  .story .summary-points li { font-size: 14.5px; }
}
</style>
</head>
<body>

{% include "_header.html.j2" %}

<main class="app-main">
  <div class="wrap">
    <div class="feed-head">
      <div class="kicker">
        <span class="dateline"><span class="live-dot"></span> {{ ref_date_label }}</span>
        <span class="label">新着フィード / TIME-ORDERED</span>
      </div>
      <h1 data-digest>今日、生成AIで何が起きたか。</h1>
      <p class="lead">本日（{{ ref_date_label }}）の更新分だけをまとめた濃いめのフィード。過去分は<a href="archive.html" style="color:var(--accent);text-decoration:underline">アーカイブ</a>、各サービスの分析は<a href="karte-index.html" style="color:var(--accent);text-decoration:underline">カルテ一覧</a>へ。</p>
    </div>
  </div>

  <!-- Category filter -->
  <div class="chip-bar">
    <div class="search-row">
      <label class="search">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="6" cy="6" r="4.3"></circle><line x1="9.5" y1="9.5" x2="13" y2="13"></line></svg>
        <input type="search" data-search placeholder="キーワードで絞り込む（見出し・要約・出典）" aria-label="キーワード検索" />
      </label>
    </div>
    <div class="chip-row" data-filter-bar>
      <button class="chip all" type="button">All</button>
      <button class="chip" data-cat="model"  aria-pressed="false"><span class="gly">◆</span>モデル/LLM</button>
      <button class="chip" data-cat="editor" aria-pressed="false"><span class="gly">▲</span>AIエディタ・コーディング</button>
      <button class="chip" data-cat="physical" aria-pressed="false"><span class="gly">⬢</span>フィジカルAI</button>
      <button class="chip" data-cat="media"  aria-pressed="false"><span class="gly">◎</span>画像・動画・音声生成</button>
      <button class="chip" data-cat="agent"  aria-pressed="false"><span class="gly">■</span>エージェント・ツール</button>
      <button class="chip" data-cat="infra"  aria-pressed="false"><span class="gly">▶</span>インフラ・チップ</button>
      <button class="chip" data-cat="policy" aria-pressed="false"><span class="gly">✦</span>規制・資金・業界</button>
    </div>
  </div>

  <div class="wrap">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:var(--s-16) var(--s-16) 0;">
      <span class="label">本日の動き</span>
      <span class="count-pill"><b data-count>{{ "%02d"|format(feed_count) }}</b> 件を表示 ・ 公開累計 {{ feed_total_published }} 件は<a href="archive.html" style="color:var(--accent)">アーカイブ</a></span>
    </div>

    <ul class="feed">
      {% if not feed %}
      <li class="story" style="display:block;text-align:center;color:var(--fg-mute);font-family:var(--font-mono);padding:var(--s-48) var(--s-16);">
        本日の更新はまだありません。過去分は<a href="archive.html" style="color:var(--accent);text-decoration:underline">アーカイブ</a>、各サービスの分析は<a href="karte-index.html" style="color:var(--accent);text-decoration:underline">カルテ一覧</a>へ。
      </li>
      {% endif %}
      {% for s in feed %}
      <li class="story{% if s.feature %} feature{% endif %}" data-filter-item data-cat="{{ s.cat }}" data-score="{{ s.score }}" data-catname="{{ s.cat_label }}"{% if s.source_url %} data-href="{{ s.source_url }}" onclick="if(!event.target.closest('a,details'))window.open('{{ s.source_url }}','_blank','noopener')"{% elif s.karte %} data-href="{{ s.karte }}" onclick="if(!event.target.closest('a,details'))location.href='{{ s.karte }}'"{% endif %}>
        <div class="score">
          <div class="num">{{ s.score }}</div>
          <div class="lbl">SCORE</div>
          <div class="date">{{ s.date_md }}<span>{{ s.date_rel }}</span></div>
        </div>
        <div class="thumb-col">
          <img class="thumb" {% if s.thumb %}data-thumb="{{ s.thumb }}"{% endif %} alt="" loading="lazy" />
          {% if s.karte_updated or s.karte_names %}
          <div class="karte-wrap">
            <span class="karte-label">— 関連カルテ —</span>
            <div class="karte-chips">
              {% if s.karte_updated %}<span class="upd-badge">UPDATE</span>{% endif %}
              {% for k in s.karte_names %}<a class="karte-chip" href="{{ k.href }}">{{ k.name }}</a>{% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
        <div class="body">
          <div class="meta-row">
            <span class="cat-badge"><span class="gly">{{ s.glyph }}</span> {{ s.cat_label }}</span>
            <div class="metrics"><span class="metric" data-level="{{ s.importance }}"{% if s.rationale.importance %} data-tip="{{ s.rationale.importance }}" tabindex="0"{% endif %}><b>重要</b><span class="bars"><i></i><i></i><i></i></span></span><span class="metric" data-level="{{ s.impact }}"{% if s.rationale.impact %} data-tip="{{ s.rationale.impact }}" tabindex="0"{% endif %}><b>影響</b><span class="bars"><i></i><i></i><i></i></span></span><span class="metric" data-level="{{ s.buzz }}"{% if s.rationale.buzz %} data-tip="{{ s.rationale.buzz }}" tabindex="0"{% endif %}><b>話題</b><span class="bars"><i></i><i></i><i></i></span></span></div>
          </div>
          <h2>{{ s.headline }}</h2>
          <div class="sect-rule"><span class="ln"></span><span class="lbl">Summary</span></div>
          {% if s.summary_points %}<ul class="summary-points">{% for p in s.summary_points %}<li>{{ p | emph }}</li>{% endfor %}</ul>{% else %}<p class="summary">{{ s.summary | emph }}</p>{% endif %}
          {% if s.rationale and (s.rationale.importance or s.rationale.impact or s.rationale.buzz) %}
          <div class="sect-rule"><span class="ln"></span><span class="lbl">Evaluate</span></div>
          <details class="why">
            <summary><span class="ic">▾</span> 判断理由（重要・影響・話題）</summary>
            <dl class="why-list">
              {% if s.rationale.importance %}<div><dt>重要</dt><dd>{{ s.rationale.importance }}</dd></div>{% endif %}
              {% if s.rationale.impact %}<div><dt>影響</dt><dd>{{ s.rationale.impact }}</dd></div>{% endif %}
              {% if s.rationale.buzz %}<div><dt>話題</dt><dd>{{ s.rationale.buzz }}</dd></div>{% endif %}
            </dl>
          </details>
          {% endif %}
          <span class="src">出典 <b style="color:var(--fg-sub);font-weight:500">{{ s.source }}</b> · <span class="tier">{{ s.tier_label }}</span>{% if s.source_url %} · <a href="{{ s.source_url }}" target="_blank" rel="noopener noreferrer" style="color:var(--cat)">記事を開く ↗</a>{% endif %}</span>
        </div>
      </li>
      {% endfor %}
    </ul>
    <div class="empty">該当するニュースがありません。フィルタを解除してください。</div>
  </div>

  {% include "_footer.html.j2" %}
</main>

<script src="app.js"></script>
</body>
</html>

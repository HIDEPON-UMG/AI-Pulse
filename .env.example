# Gemini API キー（Google AI Studio https://aistudio.google.com/apikey で生成・課金カード不要）
# 本物の .env はこのファイルをコピーしてキーを貼る（.env は .gitignore 済み）
GEMINI_API_KEY=your-key-here

# Repo Radar: GitHub metadata enrichment
GITHUB_TOKEN=github-token-with-public-repo-read

# Repo Radar: Reddit OAuth app credentials and compliant User-Agent
REDDIT_CLIENT_ID=reddit-app-client-id
REDDIT_CLIENT_SECRET=reddit-app-client-secret
# Optional: set this instead of client id/secret if you already issue a bearer token externally.
REDDIT_BEARER_TOKEN=reddit-oauth-access-token
REDDIT_USER_AGENT=windows:ai-pulse-repo-radar:v0.1 (by /u/your-reddit-username)
REPO_RADAR_SUBREDDITS=LocalLLaMA,ClaudeAI,ClaudeCode,OpenAI,MachineLearning,programming,selfhosted

# Repo Radar: X API recent search
# Keep disabled for free-first operation. Set 1 only after confirming X API credits/spending limits.
REPO_RADAR_ENABLE_X=0
X_BEARER_TOKEN=x-api-bearer-token
# One query per line. Recent search covers the last 7 days.
REPO_RADAR_X_QUERIES=github.com (AI OR agent OR agents OR LLM OR MCP OR Claude OR Codex OR Cursor OR RAG) -is:retweet lang:en

# Repo Radar: book000/twitter-rss bridge
# Point this to the output directory or XML files generated by https://github.com/book000/twitter-rss.
# Separate multiple paths or URLs with semicolons or new lines.
REPO_RADAR_X_RSS_PATHS=<path-to-twitter-rss-output>
